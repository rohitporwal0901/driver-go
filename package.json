{
  "name": "drivego-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:android": "ng build && npx cap sync android",
    "open:android": "CAPACITOR_ANDROID_STUDIO_PATH=/snap/android-studio/current/bin/studio.sh npx cap open android",
    "build:apk": "ng build && npx cap sync android && cd android && ./gradlew assembleDebug"
  },
